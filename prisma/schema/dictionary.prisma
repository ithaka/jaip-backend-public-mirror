model wordnik_ahd_5_headwords {
  headword          String  @id @unique @db.VarChar
  has_pronunciation Boolean @default(false)
  has_etymology     Boolean @default(false)
  frequency         BigInt  @default(0)

  @@index([headword])
  @@index([headword(ops: raw("gin_trgm_ops"))], type: Gin, name: "wordnik_ahd_5_headwords_headword_trgm_idx")
}
