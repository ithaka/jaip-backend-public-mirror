{
  "name": "jaip-backend",
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "build": "tsup",
    "dev": "LOG_LEVEL=info tsup --watch --onSuccess \"node --inspect dist/server.js\"",
    "test": "LOG_LEVEL=error vitest run",
    "test:ci": "LOG_LEVEL=error vitest run",
    "postinstall": "husky && prisma generate",
    "pre-commit": "lint-staged",
    "type-check": "tsc --noEmit",
    "lint:ci": "eslint src",
    "lint": "yarn lint:ci --fix",
    "format:ci": "prettier --check ./src",
    "format": "yarn format:ci --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@citation-js/core": "^0.8.2",
    "@citation-js/plugin-csl": "^0.8.2",
    "@citation-js/plugin-doi": "^0.8.2",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/postgres": "^6.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "json-2-csv": "^5.5.10",
    "pg": "^8.22.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smithy/types": "^4.16.1",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "form-data": "^4.0.6",
    "@eslint/plugin-kit": "^0.7.2",
    "tar": "^7.5.20"
  },
  "lint-staged": {
    "*.{js,ts,json,css,scss,md}": [
      "prettier --write"
    ],
    "*.{js,ts}": [
      "eslint --fix"
    ]
  }
}
